# Geolocation database paths
# The default installation places the database at:
# $HOME/.vProx/data/geolocation/ip2location.mmdb
# Override here if you want to use a different location
IP2LOCATION_MMDB=

# GeoLite2 fallback databases (optional)
GEOLITE2_COUNTRY_DB=
GEOLITE2_ASN_DB=

# Backup automation
# Backup is configured via config/backup/backup.toml (automation bool, interval, etc.)
# No env vars needed for backup — edit backup.toml directly.

# Rate limiting
VPROX_RPS=25
VPROX_BURST=100
VPROX_AUTO_ENABLED=true
VPROX_AUTO_THRESHOLD=120
VPROX_AUTO_WINDOW_SEC=10
VPROX_AUTO_RPS=1
VPROX_AUTO_BURST=1
VPROX_AUTO_TTL_SEC=900

# Server
VPROX_ADDR=:3000
