# vProx — Local-only / Ignored File Inventory
# Generated: 2026-02-22
#
# This file documents everything that is local-only, not cloneable,
# and not visible to "regular" users (people who clone the public repo).
#
# This file itself is local-only: matched by .gitignore rule:
#   agents/*.*  →  agents/ignored.list
#
# SECTIONS
# ────────
# 1. GITIGNORE PATTERN RULES         — what .gitignore declares as ignored
# 2. CURRENTLY PRESENT + IGNORED     — files on this machine that are ignored right now
# 3. TRACKED DESPITE IGNORE RULES    — files that match .gitignore patterns but are
#                                      force-tracked (policy gap; visible on remote)
# 4. LOCAL-ONLY BY CONVENTION        — no matching gitignore rule, but kept local
# 5. PUBLICLY TRACKED (REFERENCE)    — summary of what regular users DO see
#
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 1. GITIGNORE PATTERN RULES
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# ── macOS artifacts ─────────────────────────────────────────────────────────────
  .DS_Store
  .AppleDouble
  .LSOverride
  Icon
  ._*
  .DocumentRevisions-V100
  .fseventsd
  .Spotlight-V100
  .TemporaryItems
  .Trashes
  .VolumeIcon.icns
  .com.apple.timemachine.donotpresent
  .AppleDB
  .AppleDesktop
  Network Trash Folder/
  Temporary Items/
  .apdisk
#
# ── Go binaries / build output ──────────────────────────────────────────────────
  *.exe
  *.exe~
  *.dll
  *.so
  *.dylib
  vProx                          # root-level compiled binary
  .build/                        # output of `make build`
  *.test                         # `go test -c` output
  *.out
  coverage.*
  vendor/
  go.work
  go.work.sum
#
# ── Log and temporary files ─────────────────────────────────────────────────────
  logs/
  *.log
  tmp/
#
# ── Environment / secrets ───────────────────────────────────────────────────────
  .env                           # runtime secrets + paths (example: .env.example IS tracked)
#
# ── IDE and editor state ────────────────────────────────────────────────────────
  .vscode/
  .idea/
  *.swp
  *.swo
  *~
#
# ── Agent and collaboration artifacts (all local-only) ──────────────────────────
  agents/*.*                     # all files in agents/ (base, state, router files)
  agents/projects/*.*            # all project-scoped memory dumps
  docs/*.*                       # top-level files under docs/ (not subdirs)
  .github/agents/*.*             # Copilot agent manifests + config
#
# ── GitHub config hidden from regular cloners ───────────────────────────────────
  .github/CODEOWNERS
  .github/dependabot.yml
#
# ── Root-level local-only files ─────────────────────────────────────────────────
  AGENT_DIRECTIVE.md             # operational directives for this machine
  doc.go                         # package-level doc file (not part of public API surface)
  scripts/*.*                    # all scripts in scripts/
#
#
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
