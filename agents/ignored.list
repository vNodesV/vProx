# Git tracks already-committed files regardless of .gitignore.
# They ARE visible in the remote repo. They are NOT private by enforcement.
#
# If any of these should be truly private, run:
#   git rm --cached <file> && git commit -m "chore: untrack <file>"
#
  AGENT_DIRECTIVE.md             # rule: AGENT_DIRECTIVE.md (line 73)
  doc.go                         # rule: doc.go (line 74)
