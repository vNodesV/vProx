# chains/mainnet-chain.sample — Chain identity (v1.4.0) — MAINNET EXAMPLE
chain_id        = "your-chain-mainnet-1"
tree_name       = "your-chain"
dashboard_name  = "Your Chain"
network_type    = "mainnet"

[explorer]
base_url        = "https://explorer.example.com"
tx_path         = "/txs/{txhash}"
block_path      = "/blocks/{height}"
account_path    = "/accounts/{address}"
